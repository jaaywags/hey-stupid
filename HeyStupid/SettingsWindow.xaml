<Window
    x:Class="HeyStupid.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings - Hey Stupid">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="28,24,28,24">
        <StackPanel Spacing="24" MaxWidth="520">

            <!-- Reminder Folders -->
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Reminder Folders"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Click="AddSource_Click"
                            Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="Add Folder" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="Each folder stores its own reminders.json. Point a folder at OneDrive for backup or sharing."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <ListView x:Name="SourcesList"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding FolderPath}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Click="RemoveSource_Click"
                                        ToolTipService.ToolTip="Remove folder"
                                        Background="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ComboBox x:Name="DefaultFolderBox"
                          Header="Default folder for uncategorized reminders"
                          HorizontalAlignment="Stretch"
                          DisplayMemberPath="Name"
                          SelectionChanged="DefaultFolder_Changed" />
            </StackPanel>

            <NavigationViewItemSeparator />

            <!-- Categories -->
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Categories"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Click="AddCategory_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="Add Category" />
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="Categorize reminders and assign categories to folders. Uncategorized reminders go to the default folder (selected above)."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />

                <ListView x:Name="CategoriesList"
                          SelectionMode="None"
                          ContainerContentChanging="CategoriesList_ContainerContentChanging">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />

                                <ComboBox Grid.Column="1"
                                          x:Name="FolderCombo"
                                          Header=""
                                          DisplayMemberPath="Name"
                                          MinWidth="150"
                                          PlaceholderText="Folder"
                                          SelectionChanged="CategoryFolder_Changed" />

                                <Button Grid.Column="2"
                                        Click="RemoveCategory_Click"
                                        ToolTipService.ToolTip="Remove category"
                                        Background="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <NavigationViewItemSeparator />

            <!-- Startup -->
            <ToggleSwitch x:Name="StartupToggle"
                          Header="Start with Windows"
                          Toggled="StartupToggle_Toggled" />

            <NavigationViewItemSeparator />

            <!-- Defaults for New Reminders -->
            <StackPanel Spacing="12">
                <TextBlock Text="Defaults for New Reminders"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <NumberBox x:Name="DefaultRetriesBox"
                           Header="Default nag count"
                           Minimum="1"
                           Maximum="50"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="DefaultRetriesBox_ValueChanged" />
                <NumberBox x:Name="DefaultIntervalBox"
                           Header="Default minutes between nags"
                           Minimum="1"
                           Maximum="120"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="DefaultIntervalBox_ValueChanged" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>