<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package Name="Hey Stupid"
             Manufacturer="Jordan Wagner"
             Version="$(ProductVersion)"
             UpgradeCode="F8A3B1C2-D4E5-6789-ABCD-0123456789EF"
             Compressed="yes"
             InstallerVersion="500">

        <MajorUpgrade DowngradeErrorMessage="A newer version of Hey Stupid is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <!-- Icon for Add/Remove Programs -->
        <Icon Id="HeyStupidIcon" SourceFile="!(wix.IconPath)" />
        <Property Id="ARPPRODUCTICON" Value="HeyStupidIcon" />

        <Feature Id="Complete" Title="Hey Stupid" Level="1">
            <ComponentGroupRef Id="PublishOutput" />
            <ComponentRef Id="StartMenuShortcut" />
            <ComponentRef Id="DesktopShortcut" />
        </Feature>

        <!-- Install to Program Files -->
        <StandardDirectory Id="ProgramFiles6432Folder">
            <Directory Id="INSTALLFOLDER" Name="HeyStupid" />
        </StandardDirectory>

        <!-- Start Menu Shortcut -->
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="Hey Stupid">
                <Component Id="StartMenuShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-222222222222">
                    <Shortcut Id="StartMenuShortcut"
                              Name="Hey Stupid"
                              Description="Reminder application"
                              Target="[INSTALLFOLDER]HeyStupid.exe"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="HeyStupidIcon" />
                    <RemoveFolder Id="CleanStartMenu" On="uninstall" />
                    <RegistryValue Root="HKCU"
                                   Key="Software\HeyStupid"
                                   Name="StartMenuShortcut"
                                   Type="integer"
                                   Value="1"
                                   KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- Desktop Shortcut -->
        <StandardDirectory Id="DesktopFolder">
            <Component Id="DesktopShortcut" Guid="A1B2C3D4-E5F6-7890-ABCD-333333333333">
                <Shortcut Id="DesktopShortcut"
                          Name="Hey Stupid"
                          Description="Reminder application"
                          Target="[INSTALLFOLDER]HeyStupid.exe"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="HeyStupidIcon" />
                <RegistryValue Root="HKCU"
                               Key="Software\HeyStupid"
                               Name="DesktopShortcut"
                               Type="integer"
                               Value="1"
                               KeyPath="yes" />
            </Component>
        </StandardDirectory>

        <!-- Launch after install -->
        <CustomAction Id="LaunchApp" Directory="INSTALLFOLDER" ExeCommand="HeyStupid.exe" Impersonate="yes" Return="asyncNoWait" />
        <InstallExecuteSequence>
            <Custom Action="LaunchApp" After="InstallFinalize">NOT Installed AND NOT REMOVE</Custom>
        </InstallExecuteSequence>
    </Package>
</Wix>